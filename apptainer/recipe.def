Bootstrap: docker
From: nvidia/cuda:12.8.1-cudnn-devel-ubuntu24.04

%post
    apt-get update && apt-get install -y \
    python3 \
    python3-pip \
    python3-venv \
    git \
    ca-certificates \
    curl

    # Create a virtual environment in a global location
    python3 -m venv /opt/venv
    /opt/venv/bin/pip install --upgrade uv

    export PATH="/opt/venv/bin:$PATH"
    export UV_HTTP_TIMEOUT=600
    export VIRTUAL_ENV=/opt/venv
    uv pip install torch==2.9.1 torchvision
    uv pip install setuptools psutil

    uv pip install https://github.com/mjun0812/flash-attention-prebuild-wheels/releases/download/v0.9.0/flash_attn-2.8.3+cu128torch2.9-cp312-cp312-linux_x86_64.whl
    uv pip install liger-kernel

    uv pip install transformers==4.56.1
    uv pip install peft trl==0.25.1 deepspeed==0.18.1 accelerate
    uv pip install wandb
    uv pip install vllm==0.16.0

%environment
    export PATH="/opt/venv/bin:$PATH"
    export VIRTUAL_ENV=/opt/venv